[Unit]
Description=welle-cli DAB+ HTTP streamer
After=network.target
Wants=network.target

[Service]
Type=simple
WorkingDirectory=%h/dab2kodi
Environment=LD_LIBRARY_PATH=%h/dab2kodi/usr/lib/x86_64-linux-gnu/
ExecStart=%h/dab2kodi/welle-cli -c 11A -D -w 7272 -F rtl_tcp,192.168.1.1:1234
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
